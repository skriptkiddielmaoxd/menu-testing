<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Frikadellen.UI.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />

    <!-- ══════════════════════════════════════════
         GLOBAL COLOUR PALETTE
    ══════════════════════════════════════════ -->
    <Style>
      <Style.Resources>
        <!-- Backgrounds -->
        <Color x:Key="BgBase">#0A0F1E</Color>
        <Color x:Key="BgSurface">#111827</Color>
        <Color x:Key="BgCard">#1C2333</Color>
        <Color x:Key="BgSidebar">#0D1223</Color>
        <Color x:Key="BgElevated">#232D3F</Color>

        <!-- Borders -->
        <Color x:Key="BorderSubtle">#263047</Color>
        <Color x:Key="BorderMuted">#1E2A3B</Color>

        <!-- Accents -->
        <Color x:Key="AccentPrimary">#818CF8</Color>
        <Color x:Key="AccentPrimaryDim">#4F46E5</Color>
        <Color x:Key="AccentSecondary">#38BDF8</Color>
        <Color x:Key="AccentSuccess">#34D399</Color>
        <Color x:Key="AccentDanger">#F87171</Color>
        <Color x:Key="AccentWarning">#FBBF24</Color>

        <!-- Text -->
        <Color x:Key="TextPrimary">#F1F5F9</Color>
        <Color x:Key="TextSecondary">#94A3B8</Color>
        <Color x:Key="TextMuted">#475569</Color>

        <!-- Brushes -->
        <SolidColorBrush x:Key="BgBaseBrush" Color="#0A0F1E" />
        <SolidColorBrush x:Key="BgSurfaceBrush" Color="#111827" />
        <SolidColorBrush x:Key="BgCardBrush" Color="#1C2333" />
        <SolidColorBrush x:Key="BgSidebarBrush" Color="#0D1223" />
        <SolidColorBrush x:Key="BgElevatedBrush" Color="#232D3F" />
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#263047" />
        <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#818CF8" />
        <SolidColorBrush x:Key="AccentSecondaryBrush" Color="#38BDF8" />
        <SolidColorBrush x:Key="AccentSuccessBrush" Color="#34D399" />
        <SolidColorBrush x:Key="AccentDangerBrush" Color="#F87171" />
        <SolidColorBrush x:Key="AccentWarningBrush" Color="#FBBF24" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F1F5F9" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#475569" />

        <!-- Gradient brushes -->
        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Color="#818CF8" Offset="0" />
          <GradientStop Color="#38BDF8" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SuccessGradientBrush" StartPoint="0%,0%" EndPoint="100%,0%">
          <GradientStop Color="#059669" Offset="0" />
          <GradientStop Color="#34D399" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="DangerGradientBrush" StartPoint="0%,0%" EndPoint="100%,0%">
          <GradientStop Color="#DC2626" Offset="0" />
          <GradientStop Color="#F87171" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SplashBgGradientBrush" StartPoint="50%,0%" EndPoint="50%,100%">
          <GradientStop Color="#0A0F1E" Offset="0" />
          <GradientStop Color="#060B15" Offset="1" />
        </LinearGradientBrush>
      </Style.Resources>
    </Style>

    <!-- ══════════════════════════════════════════
         CARD STYLE
    ══════════════════════════════════════════ -->
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="BoxShadow" Value="0 4 20 0 #40000000" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.card-hover">
      <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="BoxShadow" Value="0 4 20 0 #40000000" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!-- ══════════════════════════════════════════
         PILL BUTTON (primary CTA)
    ══════════════════════════════════════════ -->
    <Style Selector="Button.pill-primary">
      <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="CornerRadius" Value="24" />
      <Setter Property="Padding" Value="28,12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.pill-primary:pointerover">
      <Setter Property="Background" Value="#9CA3FF" />
    </Style>
    <Style Selector="Button.pill-primary:pressed">
      <Setter Property="Background" Value="#6366F1" />
    </Style>

    <!-- Pill button — danger -->
    <Style Selector="Button.pill-danger">
      <Setter Property="Background" Value="{DynamicResource AccentDangerBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="CornerRadius" Value="24" />
      <Setter Property="Padding" Value="28,12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.pill-danger:pointerover">
      <Setter Property="Background" Value="#FF8585" />
    </Style>

    <!-- Pill button — ghost -->
    <Style Selector="Button.pill-ghost">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="CornerRadius" Value="24" />
      <Setter Property="Padding" Value="20,10" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.pill-ghost:pointerover">
      <Setter Property="Background" Value="#15818CF8" />
      <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}" />
    </Style>

    <!-- Icon button (round) -->
    <Style Selector="Button.icon-btn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.icon-btn:pointerover">
      <Setter Property="Background" Value="#20FFFFFF" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Chrome close button -->
    <Style Selector="Button.chrome-close:pointerover">
      <Setter Property="Background" Value="#EF4444" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- ══════════════════════════════════════════
         SIDEBAR NAV ITEM
    ══════════════════════════════════════════ -->
    <Style Selector="Button.nav-item">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="12,11" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.nav-item:pointerover">
      <Setter Property="Background" Value="#15818CF8" />
      <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
    </Style>
    <Style Selector="Button.nav-item.active">
      <Setter Property="Background" Value="#20818CF8" />
      <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- ══════════════════════════════════════════
         TEXT INPUT
    ══════════════════════════════════════════ -->
    <Style Selector="TextBox.field">
      <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="CaretBrush" Value="{DynamicResource AccentPrimaryBrush}" />
    </Style>
    <Style Selector="TextBox.field:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}" />
    </Style>

    <!-- ══════════════════════════════════════════
         STATUS CHIP
    ══════════════════════════════════════════ -->
    <Style Selector="Border.chip">
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="Padding" Value="10,4" />
    </Style>

    <!-- ══════════════════════════════════════════
         CHECKBOX
    ══════════════════════════════════════════ -->
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <!-- ══════════════════════════════════════════
         SCROLLVIEWER
    ══════════════════════════════════════════ -->
    <Style Selector="ScrollViewer">
      <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <!-- ══════════════════════════════════════════
         SECTION LABEL
    ══════════════════════════════════════════ -->
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="LetterSpacing" Value="1" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- ══════════════════════════════════════════
         SEPARATOR
    ══════════════════════════════════════════ -->
    <Style Selector="Border.divider">
      <Setter Property="Background" Value="{DynamicResource BorderSubtleBrush}" />
      <Setter Property="Height" Value="1" />
      <Setter Property="Margin" Value="0,12" />
    </Style>

  </Application.Styles>
</Application>
