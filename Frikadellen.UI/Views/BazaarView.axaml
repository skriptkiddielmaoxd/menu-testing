<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             xmlns:m="using:Frikadellen.UI.Models"
             xmlns:ctrl="using:Frikadellen.UI.Controls"
             xmlns:cvt="using:Frikadellen.UI.Converters"
             x:Class="Frikadellen.UI.Views.BazaarView"
             x:DataType="vm:BazaarViewModel">

  <UserControl.Resources>
    <cvt:StringToBrushConverter x:Key="StrBrush" />
  </UserControl.Resources>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="20" Margin="0,0,0,20">

      <!-- Active Orders -->
      <Border Background="#0DFFFFFF" CornerRadius="12" Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="Active Bazaar Orders" FontSize="14" FontWeight="Bold" Foreground="#E0E7FF" />
          <ItemsControl ItemsSource="{Binding ActiveOrders}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="m:BazaarOrder">
                <Border Background="#08FFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,4">
                  <Grid ColumnDefinitions="*,80,80,80,80">
                    <TextBlock Grid.Column="0" Text="{Binding ItemName}" FontSize="13" Foreground="#E0E7FF" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding OrderType}" FontSize="12" Foreground="#38BDF8" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding PriceLabel}" FontSize="12" Foreground="#818CF8" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="3" Text="{Binding Amount}" FontSize="12" Foreground="#9CA3AF" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    <Border Grid.Column="4" Background="#15FFFFFF" CornerRadius="6" Padding="6,3" HorizontalAlignment="Right" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Status}" FontSize="11"
                                 Foreground="{Binding StatusColor, Converter={StaticResource StrBrush}}" />
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Bazaar Flip History + Donut chart -->
      <Grid ColumnDefinitions="*,Auto">
        <Border Grid.Column="0" Background="#0DFFFFFF" CornerRadius="12" Padding="16" Margin="0,0,12,0">
          <StackPanel Spacing="12">
            <TextBlock Text="Bazaar Flip History" FontSize="14" FontWeight="Bold" Foreground="#E0E7FF" />
            <ItemsControl ItemsSource="{Binding BazaarFlips}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="m:FlipRecord">
                  <Border Background="#08FFFFFF" CornerRadius="8" Padding="10,6" Margin="0,0,0,3">
                    <Grid ColumnDefinitions="*,90,90,80">
                      <TextBlock Grid.Column="0" Text="{Binding ItemName}" FontSize="12" Foreground="#E0E7FF" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding BuyLabel}" FontSize="12" Foreground="#9CA3AF" VerticalAlignment="Center" HorizontalAlignment="Right" />
                      <TextBlock Grid.Column="2" Text="{Binding SellLabel}" FontSize="12" Foreground="#9CA3AF" VerticalAlignment="Center" HorizontalAlignment="Right" />
                      <TextBlock Grid.Column="3" Text="{Binding ProfitLabel}" FontSize="12" Foreground="#34D399" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#0DFFFFFF" CornerRadius="12" Padding="16" Width="200">
          <StackPanel Spacing="8" HorizontalAlignment="Center">
            <TextBlock Text="Order Distribution" FontSize="13" FontWeight="SemiBold" Foreground="#E0E7FF" HorizontalAlignment="Center" />
            <ctrl:DonutChartControl Width="150" Height="150" SuccessRate="0.55" FailRate="0.30" PendingRate="0.15" />
            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="8" Height="8" Fill="#34D399" VerticalAlignment="Center" />
                <TextBlock Text="BUY" FontSize="11" Foreground="#9CA3AF" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="8" Height="8" Fill="#F87171" VerticalAlignment="Center" />
                <TextBlock Text="SELL" FontSize="11" Foreground="#9CA3AF" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="8" Height="8" Fill="#FBBF24" VerticalAlignment="Center" />
                <TextBlock Text="PENDING" FontSize="11" Foreground="#9CA3AF" />
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Hourly Profit Comparison (AH vs Bazaar) -->
      <Border Background="#0DFFFFFF" CornerRadius="12" Padding="16">
        <StackPanel Spacing="8">
          <TextBlock Text="Hourly Profit (Bazaar)" FontSize="14" FontWeight="Bold" Foreground="#E0E7FF" />
          <ctrl:BarChartControl Values="{Binding AhVsBazaarData}" Height="120" HighlightIndex="{Binding CurrentHour}" />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
