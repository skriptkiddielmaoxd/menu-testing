<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             xmlns:m="using:Frikadellen.UI.Models"
             xmlns:ctrl="using:Frikadellen.UI.Controls"
             x:Class="Frikadellen.UI.Views.AnalyticsView"
             x:DataType="vm:AnalyticsViewModel">

  <UserControl.Resources>
    <vm:StringToBrushConverter x:Key="StrBrush" />
  </UserControl.Resources>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="20" Margin="0,0,0,20">

      <!-- KPI cards row -->
      <WrapPanel Orientation="Horizontal">
        <Border Background="#12FFFFFF" CornerRadius="12" Padding="16,12" Margin="0,0,12,12" MinWidth="160">
          <StackPanel Spacing="4">
            <TextBlock Text="Total Profit" FontSize="11" Foreground="#9CA3AF" />
            <TextBlock Text="{Binding TotalProfit}" FontSize="22" FontWeight="Bold" Foreground="#34D399" />
          </StackPanel>
        </Border>
        <Border Background="#12FFFFFF" CornerRadius="12" Padding="16,12" Margin="0,0,12,12" MinWidth="160">
          <StackPanel Spacing="4">
            <TextBlock Text="Avg Profit/Flip" FontSize="11" Foreground="#9CA3AF" />
            <TextBlock Text="{Binding AvgProfitPerFlip}" FontSize="22" FontWeight="Bold" Foreground="#818CF8" />
          </StackPanel>
        </Border>
        <Border Background="#12FFFFFF" CornerRadius="12" Padding="16,12" Margin="0,0,12,12" MinWidth="160">
          <StackPanel Spacing="4">
            <TextBlock Text="Best Flip" FontSize="11" Foreground="#9CA3AF" />
            <TextBlock Text="{Binding BestFlipProfit}" FontSize="22" FontWeight="Bold" Foreground="#FFAA00" />
            <TextBlock Text="{Binding BestFlipItem}" FontSize="11" Foreground="#6B7280" />
          </StackPanel>
        </Border>
        <Border Background="#12FFFFFF" CornerRadius="12" Padding="16,12" Margin="0,0,12,12" MinWidth="160">
          <StackPanel Spacing="4">
            <TextBlock Text="Flips/Hour" FontSize="11" Foreground="#9CA3AF" />
            <TextBlock Text="{Binding FlipsPerHour}" FontSize="22" FontWeight="Bold" Foreground="#38BDF8" />
          </StackPanel>
        </Border>
        <Border Background="#12FFFFFF" CornerRadius="12" Padding="16,12" Margin="0,0,12,12" MinWidth="160">
          <StackPanel Spacing="4">
            <TextBlock Text="Avg Buy Speed" FontSize="11" Foreground="#9CA3AF" />
            <TextBlock Text="{Binding AvgBuySpeed}" FontSize="22" FontWeight="Bold" Foreground="#E879F9" />
          </StackPanel>
        </Border>
        <Border Background="#12FFFFFF" CornerRadius="12" Padding="16,12" Margin="0,0,12,12" MinWidth="160">
          <StackPanel Spacing="4">
            <TextBlock Text="Win Rate" FontSize="11" Foreground="#9CA3AF" />
            <TextBlock Text="{Binding WinRate}" FontSize="22" FontWeight="Bold" Foreground="#34D399" />
          </StackPanel>
        </Border>
      </WrapPanel>

      <!-- Charts row -->
      <Grid ColumnDefinitions="*,Auto">
        <Border Grid.Column="0" Background="#0DFFFFFF" CornerRadius="12" Padding="16" Margin="0,0,12,0">
          <StackPanel Spacing="8">
            <TextBlock Text="Profit Timeline" FontSize="13" FontWeight="SemiBold" Foreground="#E0E7FF" />
            <ctrl:LineChartControl DataPoints="{Binding ProfitTimeline}" Height="140" />
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Background="#0DFFFFFF" CornerRadius="12" Padding="16" Width="260">
          <StackPanel Spacing="8">
            <TextBlock Text="Hourly Earnings" FontSize="13" FontWeight="SemiBold" Foreground="#E0E7FF" />
            <ctrl:BarChartControl Values="{Binding HourlyEarnings}" Height="140" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Top Items leaderboard -->
      <Border Background="#0DFFFFFF" CornerRadius="12" Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="Top Items" FontSize="14" FontWeight="Bold" Foreground="#E0E7FF" />
          <ItemsControl ItemsSource="{Binding TopItems}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="m:TopItemEntry">
                <Border Background="#08FFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,4">
                  <Grid ColumnDefinitions="40,*,100,100,100">
                    <TextBlock Grid.Column="0" Text="{Binding RankLabel}" FontSize="16" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding ItemName}" FontSize="13" Foreground="#E0E7FF" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding TotalProfitLabel}" FontSize="12" Foreground="#34D399" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="3" Text="{Binding AvgProfitLabel}" FontSize="12" Foreground="#818CF8" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="4" Text="{Binding BestProfitLabel}" FontSize="12" Foreground="#FFAA00" VerticalAlignment="Center" HorizontalAlignment="Right" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
