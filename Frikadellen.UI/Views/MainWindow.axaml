<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Frikadellen.UI.ViewModels"
        xmlns:views="using:Frikadellen.UI.Views"
        xmlns:m="using:Frikadellen.UI.Models"
        x:Class="Frikadellen.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Frikadellen"
        Width="1280" Height="780"
        MinWidth="920" MinHeight="560"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="CenterScreen">

  <Window.Styles>

    <!-- ═══ ANIMATED BACKGROUND ORBS ═══ -->
    <Style Selector="Ellipse.orb-fuchsia">
      <Style.Animations>
        <Animation Duration="0:0:16" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
          <KeyFrame Cue="0%">
            <Setter Property="TranslateTransform.X" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="0" />
            <Setter Property="Opacity" Value="0.12" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="TranslateTransform.X" Value="140" />
            <Setter Property="TranslateTransform.Y" Value="80" />
            <Setter Property="Opacity" Value="0.18" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="Ellipse.orb-cyan">
      <Style.Animations>
        <Animation Duration="0:0:20" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
          <KeyFrame Cue="0%">
            <Setter Property="TranslateTransform.X" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="0" />
            <Setter Property="Opacity" Value="0.10" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="TranslateTransform.X" Value="-120" />
            <Setter Property="TranslateTransform.Y" Value="-60" />
            <Setter Property="Opacity" Value="0.16" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="Ellipse.orb-orange">
      <Style.Animations>
        <Animation Duration="0:0:14" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
          <KeyFrame Cue="0%">
            <Setter Property="TranslateTransform.X" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="0" />
            <Setter Property="Opacity" Value="0.06" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="TranslateTransform.X" Value="80" />
            <Setter Property="TranslateTransform.Y" Value="-90" />
            <Setter Property="Opacity" Value="0.10" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- View host fade+slide transition -->
    <Style Selector="ContentControl.view-host">
      <Style.Animations>
        <Animation Duration="0:0:0.32" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="20" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Chrome button base -->
    <Style Selector="Button.chrome-btn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#6B5F8A" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="28" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Button.chrome-btn:pointerover">
      <Setter Property="Background" Value="#18FFFFFF" />
      <Setter Property="Foreground" Value="#A78BFA" />
    </Style>
    <Style Selector="Button.chrome-close:pointerover">
      <Setter Property="Background" Value="#FB7185" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Status chip colour transition -->
    <Style Selector="Border.status-chip">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.3" />
        </Transitions>
      </Setter>
    </Style>

    <!-- Nav bar fade-in -->
    <Style Selector="Border.nav-strip">
      <Style.Animations>
        <Animation Duration="0:0:0.5" Delay="0:0:0.1" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="-8" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

  </Window.Styles>

  <Window.Resources>
    <vm:StringToBrushConverter x:Key="StrBrush" />
  </Window.Resources>

  <!-- Root: rounded window with drop shadow -->
  <Border CornerRadius="18"
          ClipToBounds="True"
          BoxShadow="0 12 60 0 #90000000, 0 0 1 0 #20E879F9"
          Background="{DynamicResource BgBaseBrush}">

    <!-- Full-screen grid: animated BG + splash/login overlay + shell -->
    <Grid>

      <!-- ═══════════════════════════════════════
           ANIMATED BACKGROUND — Floating gradient orbs
      ═══════════════════════════════════════ -->
      <Canvas IsHitTestVisible="False" ClipToBounds="True">
        <!-- Fuchsia orb — top left -->
        <Ellipse Width="600" Height="600" Classes="orb-fuchsia"
                 Canvas.Left="-150" Canvas.Top="-200">
          <Ellipse.RenderTransform><TranslateTransform /></Ellipse.RenderTransform>
          <Ellipse.Fill>
            <RadialGradientBrush>
              <GradientStop Color="#E879F9" Offset="0" />
              <GradientStop Color="#00E879F9" Offset="1" />
            </RadialGradientBrush>
          </Ellipse.Fill>
        </Ellipse>

        <!-- Cyan orb — bottom right -->
        <Ellipse Width="500" Height="500" Classes="orb-cyan"
                 Canvas.Left="700" Canvas.Top="300">
          <Ellipse.RenderTransform><TranslateTransform /></Ellipse.RenderTransform>
          <Ellipse.Fill>
            <RadialGradientBrush>
              <GradientStop Color="#22D3EE" Offset="0" />
              <GradientStop Color="#0022D3EE" Offset="1" />
            </RadialGradientBrush>
          </Ellipse.Fill>
        </Ellipse>

        <!-- Orange orb — center-right -->
        <Ellipse Width="350" Height="350" Classes="orb-orange"
                 Canvas.Left="900" Canvas.Top="-50">
          <Ellipse.RenderTransform><TranslateTransform /></Ellipse.RenderTransform>
          <Ellipse.Fill>
            <RadialGradientBrush>
              <GradientStop Color="#FB923C" Offset="0" />
              <GradientStop Color="#00FB923C" Offset="1" />
            </RadialGradientBrush>
          </Ellipse.Fill>
        </Ellipse>
      </Canvas>

      <!-- ═══════════════════════════════════════
           SPLASH / LOGIN (overlay phases)
      ═══════════════════════════════════════ -->
      <ContentControl Content="{Binding CurrentView}"
                      IsVisible="{Binding !IsShell}"
                      Classes="view-host">
        <ContentControl.RenderTransform>
          <TranslateTransform />
        </ContentControl.RenderTransform>
        <ContentControl.ContentTemplate>
          <DataTemplate>
            <ContentControl Content="{Binding}">
              <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:SplashViewModel">
                  <views:SplashView />
                </DataTemplate>
                <DataTemplate DataType="vm:LoginViewModel">
                  <views:LoginView />
                </DataTemplate>
              </ContentControl.DataTemplates>
            </ContentControl>
          </DataTemplate>
        </ContentControl.ContentTemplate>
      </ContentControl>

      <!-- ═══════════════════════════════════════
           MAIN SHELL — Horizontal nav + content (no sidebar)
      ═══════════════════════════════════════ -->
      <Grid RowDefinitions="42,Auto,*"
            IsVisible="{Binding IsShell}">

        <!-- ── TITLE BAR ── -->
        <Border Grid.Row="0"
                Background="#0D0A16"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Name="TitleBar">
          <Grid ColumnDefinitions="Auto,*,Auto">

            <!-- Left: logo + title + status chip -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="12" Margin="16,0,0,0"
                        VerticalAlignment="Center">
              <!-- Logo — hexagonal feel -->
              <Border Width="26" Height="26"
                      CornerRadius="8"
                      Background="#20E879F9"
                      BorderBrush="#40E879F9"
                      BorderThickness="1"
                      BoxShadow="0 0 12 0 #30E879F9">
                <TextBlock Text="◆" FontSize="12"
                           Foreground="{DynamicResource AccentPrimaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>

              <TextBlock Text="Frikadellen"
                         FontSize="14" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         VerticalAlignment="Center" />

              <!-- Status chip -->
              <Border Classes="status-chip chip"
                      Background="#4ADE8020"
                      VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <Ellipse Width="6" Height="6"
                           Fill="{DynamicResource AccentSuccessBrush}" />
                  <TextBlock Text="{Binding StatusText}"
                             FontSize="11" FontWeight="Medium"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- Centre: drag handle -->
            <Border Grid.Column="1" Background="Transparent" Name="DragRegion" />

            <!-- Right: chrome controls -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="2" Margin="0,0,8,0"
                        VerticalAlignment="Center">
              <Button Classes="chrome-btn"
                      Content="◐"
                      ToolTip.Tip="Toggle theme"
                      Command="{Binding ToggleThemeCommand}" />
              <Button Classes="chrome-btn"
                      Content="—"
                      ToolTip.Tip="Minimise"
                      Name="MinimizeButton" />
              <Button Classes="chrome-btn"
                      Content="⬜"
                      ToolTip.Tip="Maximise / Restore"
                      Name="MaximizeButton" />
              <Button Classes="chrome-btn chrome-close"
                      Content="✕"
                      ToolTip.Tip="Close"
                      Name="CloseButton" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- ── HORIZONTAL NAVIGATION BAR ── -->
        <Border Grid.Row="1"
                Classes="nav-strip"
                Background="#0A0714"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,6"
                Opacity="0"
                RenderTransformOrigin="0.5,0">
          <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>

          <StackPanel Orientation="Horizontal" Spacing="4"
                      HorizontalAlignment="Center">

            <Button Classes="nav-item"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="Dashboard"
                    ToolTip.Tip="Dashboard">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="◈" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="Dashboard" FontSize="13" VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button Classes="nav-item"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="Events"
                    ToolTip.Tip="Live Events">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⚡" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="Events" FontSize="13" VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button Classes="nav-item"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="Config"
                    ToolTip.Tip="Configuration">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="Config" FontSize="13" VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button Classes="nav-item"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="Notifier"
                    ToolTip.Tip="Notifier">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="🔔" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="Notifier" FontSize="13" VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button Classes="nav-item"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="Console"
                    ToolTip.Tip="Console">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⬛" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="Console" FontSize="13" VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button Classes="nav-item"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="Analytics"
                    ToolTip.Tip="Analytics">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="📈" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="Analytics" FontSize="13" VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button Classes="nav-item"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="Bazaar"
                    ToolTip.Tip="Bazaar">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="📦" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="Bazaar" FontSize="13" VerticalAlignment="Center" />
              </StackPanel>
            </Button>

          </StackPanel>
        </Border>

        <!-- ── MAIN CONTENT AREA ── -->
        <Border Grid.Row="2"
                Background="Transparent"
                CornerRadius="0,0,18,18"
                ClipToBounds="True"
                Padding="28,22">
          <ContentControl Content="{Binding CurrentView}"
                          Classes="view-host"
                          IsVisible="{Binding IsShell}">
            <ContentControl.RenderTransform>
              <TranslateTransform />
            </ContentControl.RenderTransform>
            <ContentControl.ContentTemplate>
              <DataTemplate>
                <ContentControl Content="{Binding}">
                  <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:DashboardViewModel">
                      <views:DashboardView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:EventsViewModel">
                      <views:EventsView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:ConfigViewModel">
                      <views:ConfigView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:NotifierViewModel">
                      <views:NotifierView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:ConsoleViewModel">
                      <views:ConsoleView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:AnalyticsViewModel">
                      <views:AnalyticsView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:BazaarViewModel">
                      <views:BazaarView />
                    </DataTemplate>
                  </ContentControl.DataTemplates>
                </ContentControl>
              </DataTemplate>
            </ContentControl.ContentTemplate>
          </ContentControl>
        </Border>

      </Grid>

      <!-- ═══════════════════════════════════════
           TOAST OVERLAY
      ═══════════════════════════════════════ -->
      <Panel IsHitTestVisible="False" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,24,24">
        <ItemsControl ItemsSource="{Binding ToastService.Toasts}" IsHitTestVisible="False">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="m:ToastItem">
              <Border Background="#1E1B2E" CornerRadius="10" Padding="14,10" Margin="0,0,0,8"
                      BorderThickness="1"
                      BorderBrush="{Binding TypeColor, Converter={StaticResource StrBrush}}"
                      MinWidth="260" MaxWidth="380">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="{Binding TypeIcon}" FontSize="16" VerticalAlignment="Center"
                             Foreground="{Binding TypeColor, Converter={StaticResource StrBrush}}" />
                  <TextBlock Text="{Binding Message}" FontSize="12" Foreground="#E0E7FF"
                             VerticalAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Panel>

    </Grid>
  </Border>
</Window>
