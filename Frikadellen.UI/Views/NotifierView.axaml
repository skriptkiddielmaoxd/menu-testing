<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             x:Class="Frikadellen.UI.Views.NotifierView"
             x:DataType="vm:NotifierViewModel">

  <UserControl.Styles>
    <!-- Card stagger -->
    <Style Selector="Border.notif-card-1">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.0" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="18" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.notif-card-2">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.1" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="18" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.notif-card-3">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.2" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="18" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="0" Margin="0,0,8,0" MaxWidth="720">

      <!-- ── PAGE HEADER ── -->
      <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Notifier"
                     FontSize="26" FontWeight="ExtraBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="Discord bot and webhook notification settings"
                     FontSize="13"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                    VerticalAlignment="Center">
          <TextBlock Text="{Binding SaveStatus}"
                     FontSize="12"
                     Foreground="{DynamicResource AccentSuccessBrush}"
                     VerticalAlignment="Center"
                     Opacity="0.9" />
          <Button Classes="pill-primary"
                  Command="{Binding SaveCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <TextBlock Text="💾" FontSize="13" VerticalAlignment="Center" />
              <TextBlock Text="Save" FontSize="13" FontWeight="SemiBold"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <!-- ════ DISCORD BOT ════ -->
      <Border Classes="card notif-card-1"
              Padding="0"
              ClipToBounds="True"
              RenderTransformOrigin="0.5,1"
              Opacity="0">
        <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>
        <StackPanel>
          <!-- Gradient accent top -->
          <Border Height="2">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                <GradientStop Color="#5865F2" Offset="0" />
                <GradientStop Color="#E879F9" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <StackPanel Spacing="16" Margin="22,18,22,22">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Border Width="30" Height="30" CornerRadius="10"
                      Background="#185865F2"
                      BoxShadow="0 0 8 0 #155865F2">
                <TextBlock Text="🤖" FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="Discord Bot"
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <Border Classes="divider" />

            <!-- Info banner -->
            <Border CornerRadius="12" Padding="14,12"
                    Background="#10E879F9"
                    BorderBrush="#18E879F9"
                    BorderThickness="1">
              <TextBlock TextWrapping="Wrap" FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}">
                <Run Text="The bot responds to " />
                <Run Text="!start" FontFamily="Consolas,Monospace" FontWeight="SemiBold"
                     Foreground="{DynamicResource AccentPrimaryBrush}" />
                <Run Text=" / " />
                <Run Text="!stop" FontFamily="Consolas,Monospace" FontWeight="SemiBold"
                     Foreground="{DynamicResource AccentPrimaryBrush}" />
                <Run Text=" / " />
                <Run Text="!status" FontFamily="Consolas,Monospace" FontWeight="SemiBold"
                     Foreground="{DynamicResource AccentPrimaryBrush}" />
                <Run Text=" and sends rich embed notifications for purchases, sales and events." />
              </TextBlock>
            </Border>

            <!-- Bot token -->
            <StackPanel Spacing="6">
              <TextBlock Text="BOT TOKEN" Classes="section-title" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Classes="field"
                         Text="{Binding DiscordBotToken}"
                         Watermark="Your Discord bot token…"
                         PasswordChar="{Binding TokenPasswordChar}"
                         Margin="0,0,8,0" />
                <Button Grid.Column="1"
                        Classes="icon-btn"
                        Width="40" Height="40"
                        CornerRadius="10"
                        Background="{DynamicResource BgElevatedBrush}"
                        Command="{Binding ToggleTokenVisibilityCommand}"
                        ToolTip.Tip="Show/hide token">
                  <TextBlock Text="{Binding IsTokenVisible, Converter={x:Static vm:ShowHideConverter.Instance}}"
                             FontSize="14"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Button>
              </Grid>
            </StackPanel>

            <!-- Channel ID -->
            <StackPanel Spacing="6">
              <TextBlock Text="CHANNEL ID (optional)" Classes="section-title" />
              <TextBox Classes="field"
                       Text="{Binding DiscordChannelId}"
                       Watermark="e.g. 123456789012345678" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ════ WEBHOOK ════ -->
      <Border Classes="card notif-card-2"
              Padding="0"
              ClipToBounds="True"
              RenderTransformOrigin="0.5,1"
              Opacity="0">
        <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>
        <StackPanel>
          <Border Height="2">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                <GradientStop Color="#4ADE80" Offset="0" />
                <GradientStop Color="#22D3EE" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <StackPanel Spacing="16" Margin="22,18,22,22">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Border Width="30" Height="30" CornerRadius="10"
                      Background="#184ADE80"
                      BoxShadow="0 0 8 0 #154ADE80">
                <TextBlock Text="🪝" FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="Discord Webhook"
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <Border Classes="divider" />

            <Border CornerRadius="12" Padding="14,12"
                    Background="#10FBBF24"
                    BorderBrush="#18FBBF24"
                    BorderThickness="1">
              <TextBlock TextWrapping="Wrap" FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         Text="A webhook is a lightweight alternative — one-way notifications only (no remote control). Set empty to disable." />
            </Border>

            <StackPanel Spacing="6">
              <TextBlock Text="WEBHOOK URL" Classes="section-title" />
              <TextBox Classes="field"
                       Text="{Binding WebhookUrl}"
                       Watermark="https://discord.com/api/webhooks/…" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ════ COMMANDS QUICK REFERENCE ════ -->
      <Border Classes="card notif-card-3"
              Padding="0"
              ClipToBounds="True"
              RenderTransformOrigin="0.5,1"
              Opacity="0">
        <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>
        <StackPanel>
          <Border Height="2">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                <GradientStop Color="#FB923C" Offset="0" />
                <GradientStop Color="#FB7185" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <StackPanel Spacing="14" Margin="22,18,22,22">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Border Width="30" Height="30" CornerRadius="10"
                      Background="#18FB923C"
                      BoxShadow="0 0 8 0 #15FB923C">
                <TextBlock Text="📋" FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="Bot Commands"
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <Border Classes="divider" />

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto"
                  Margin="0,4,0,0">
              <!-- !start -->
              <Border Grid.Column="0" Grid.Row="0"
                      CornerRadius="8" Padding="10,5"
                      Background="{DynamicResource BgElevatedBrush}"
                      Margin="0,0,14,10">
                <TextBlock Text="!start"
                           FontFamily="Consolas,Monospace"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentSuccessBrush}" />
              </Border>
              <TextBlock Grid.Column="1" Grid.Row="0"
                         Text="Resume flip purchasing"
                         FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center"
                         Margin="0,0,0,10" />

              <!-- !stop -->
              <Border Grid.Column="0" Grid.Row="1"
                      CornerRadius="8" Padding="10,5"
                      Background="{DynamicResource BgElevatedBrush}"
                      Margin="0,0,14,10">
                <TextBlock Text="!stop"
                           FontFamily="Consolas,Monospace"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentDangerBrush}" />
              </Border>
              <TextBlock Grid.Column="1" Grid.Row="1"
                         Text="Pause flip purchasing (bot stays connected)"
                         FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center"
                         Margin="0,0,0,10" />

              <!-- !status -->
              <Border Grid.Column="0" Grid.Row="2"
                      CornerRadius="8" Padding="10,5"
                      Background="{DynamicResource BgElevatedBrush}"
                      Margin="0,0,14,0">
                <TextBlock Text="!status"
                           FontFamily="Consolas,Monospace"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentSecondaryBrush}" />
              </Border>
              <TextBlock Grid.Column="1" Grid.Row="2"
                         Text="Show current state, purse, bot status and queue"
                         FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </Grid>

          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
