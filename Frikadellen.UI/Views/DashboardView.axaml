<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             xmlns:m="using:Frikadellen.UI.Models"
             x:Class="Frikadellen.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

  <UserControl.Resources>
    <vm:BoolToStringConverter x:Key="BoolToRunningText"
                               TrueValue="Running" FalseValue="Stopped" />
    <vm:BoolToColorConverter x:Key="BoolToRunningColor"
                              TrueColor="#34D399" FalseColor="#F87171" />
  </UserControl.Resources>

  <UserControl.Styles>

    <!-- Stat card stagger-in: card 1 -->
    <Style Selector="Border.stat-1">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.0" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="20" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.stat-2">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.08" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="20" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.stat-3">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.16" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="20" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.stat-4">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.24" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="20" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Toggle button scale transition -->
    <Style Selector="Button.toggle-btn">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.3" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.toggle-btn:pressed">
      <Setter Property="RenderTransform">
        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
      </Setter>
    </Style>

    <!-- Flip row slide-in (applied per item via ItemContainerTheme not possible in Avalonia easily,
         so we apply to the list itself) -->
    <Style Selector="Border.flips-section">
      <Style.Animations>
        <Animation Duration="0:0:0.4" Delay="0:0:0.3" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="16" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="0" Margin="0,0,8,0">

      <!-- ── PAGE HEADER ── -->
      <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,24">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Dashboard"
                     FontSize="26" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="Live bot metrics and controls"
                     FontSize="13"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>

        <!-- Start / Stop CTA -->
        <Button Grid.Column="1"
                Classes="toggle-btn"
                CornerRadius="24"
                Padding="26,13"
                FontWeight="Bold"
                FontSize="14"
                Cursor="Hand"
                VerticalAlignment="Center"
                Background="{Binding ToggleButtonColor}"
                Foreground="White"
                Command="{Binding ToggleCommand}"
                RenderTransformOrigin="0.5,0.5">
          <Button.RenderTransform>
            <ScaleTransform />
          </Button.RenderTransform>
          <TextBlock Text="{Binding ToggleButtonLabel}"
                     FontSize="14" FontWeight="Bold" />
        </Button>
      </Grid>

      <!-- ── STAT CARDS ROW ── -->
      <Grid ColumnDefinitions="*,*,*,*" Margin="0,0,0,20">

        <!-- Card 1: Script State -->
        <Border Grid.Column="0" Classes="card stat-1"
                Margin="0,0,10,0"
                RenderTransformOrigin="0.5,1">
          <Border.RenderTransform>
            <TranslateTransform />
          </Border.RenderTransform>
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Width="32" Height="32" CornerRadius="10"
                      Background="#15818CF8">
                <TextBlock Text="▦" FontSize="14"
                           Foreground="{DynamicResource AccentPrimaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="SCRIPT" Classes="section-title"
                         VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding ScriptState}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{Binding IsRunning, Converter={StaticResource BoolToRunningColor}}" />
            <TextBlock Text="Current state"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </StackPanel>
        </Border>

        <!-- Card 2: Purse -->
        <Border Grid.Column="1" Classes="card stat-2"
                Margin="0,0,10,0"
                RenderTransformOrigin="0.5,1">
          <Border.RenderTransform>
            <TranslateTransform />
          </Border.RenderTransform>
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Width="32" Height="32" CornerRadius="10"
                      Background="#15FBBF24">
                <TextBlock Text="💰" FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="PURSE" Classes="section-title"
                         VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding Purse}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource AccentWarningBrush}" />
            <TextBlock Text="Current balance"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </StackPanel>
        </Border>

        <!-- Card 3: Queue -->
        <Border Grid.Column="2" Classes="card stat-3"
                Margin="0,0,10,0"
                RenderTransformOrigin="0.5,1">
          <Border.RenderTransform>
            <TranslateTransform />
          </Border.RenderTransform>
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Width="32" Height="32" CornerRadius="10"
                      Background="#1538BDF8">
                <TextBlock Text="⚡" FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="QUEUE" Classes="section-title"
                         VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding QueueDepth}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource AccentSecondaryBrush}" />
            <TextBlock Text="Flips pending"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </StackPanel>
        </Border>

        <!-- Card 4: Session profit -->
        <Border Grid.Column="3" Classes="card stat-4"
                RenderTransformOrigin="0.5,1">
          <Border.RenderTransform>
            <TranslateTransform />
          </Border.RenderTransform>
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Width="32" Height="32" CornerRadius="10"
                      Background="#1534D399">
                <TextBlock Text="📈" FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="PROFIT" Classes="section-title"
                         VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding SessionProfit}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource AccentSuccessBrush}" />
            <TextBlock Text="{Binding SessionFlips, StringFormat='Session: {0} flips'}"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- ── LATEST FLIP HIGHLIGHT ── -->
      <Border Classes="card flips-section"
              IsVisible="{Binding LatestFlip, Converter={x:Static vm:NullToBoolConverter.Instance}}"
              RenderTransformOrigin="0.5,0.5"
              Margin="0,0,0,20">
        <Border.RenderTransform>
          <TranslateTransform />
        </Border.RenderTransform>
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border Grid.Column="0" Width="42" Height="42"
                  CornerRadius="12"
                  Background="#15818CF8"
                  VerticalAlignment="Center"
                  Margin="0,0,14,0">
            <TextBlock Text="🛒" FontSize="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
            <TextBlock Text="Latest Flip"
                       FontSize="11" Classes="section-title"
                       Margin="0" />
            <TextBlock Text="{Binding LatestFlip.ItemName}"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Right"
                      VerticalAlignment="Center">
            <TextBlock Text="{Binding LatestFlip.ProfitLabel}"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource AccentSuccessBrush}"
                       HorizontalAlignment="Right" />
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
              <TextBlock Text="{Binding LatestFlip.BuyLabel, StringFormat='Buy: {0}'}"
                         FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="→"
                         FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding LatestFlip.SellLabel, StringFormat='Sell: {0}'}"
                         FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <Border CornerRadius="8" Padding="6,2"
                      Background="#1534D399">
                <TextBlock Text="{Binding LatestFlip.SpeedLabel}"
                           FontSize="10" FontWeight="Medium"
                           Foreground="{DynamicResource AccentSuccessBrush}" />
              </Border>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ── RECENT FLIPS TABLE ── -->
      <Border Classes="card"
              RenderTransformOrigin="0.5,1">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Recent Flips"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <Border CornerRadius="10" Padding="7,2"
                    Background="{DynamicResource BgElevatedBrush}"
                    VerticalAlignment="Center">
              <TextBlock Text="{Binding RecentFlips.Count}"
                         FontSize="11" FontWeight="Medium"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </Border>
          </StackPanel>

          <!-- Table header -->
          <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Text="ITEM" Classes="section-title" Margin="0" />
            <TextBlock Grid.Column="1" Text="BUY" Classes="section-title" Margin="0,0,24,0" />
            <TextBlock Grid.Column="2" Text="SELL" Classes="section-title" Margin="0,0,24,0" />
            <TextBlock Grid.Column="3" Text="PROFIT" Classes="section-title" Margin="0,0,24,0" />
            <TextBlock Grid.Column="4" Text="SPEED" Classes="section-title" Margin="0" />
          </Grid>

          <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,0,0,4" />

          <!-- Flip rows -->
          <ItemsControl ItemsSource="{Binding RecentFlips}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="m:FlipRecord">
                <Border Padding="0,8" CornerRadius="8">
                  <Border.Styles>
                    <Style Selector="Border:pointerover">
                      <Setter Property="Background" Value="#0DFFFFFF" />
                    </Style>
                  </Border.Styles>
                  <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                      <Border Width="28" Height="28" CornerRadius="8"
                              Background="{DynamicResource BgElevatedBrush}">
                        <TextBlock Text="🏷️" FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                      </Border>
                      <TextBlock Text="{Binding ItemName}"
                                 FontSize="13"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding BuyLabel}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,24,0" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding SellLabel}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,24,0" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding ProfitLabel}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentSuccessBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,24,0" />
                    <Border Grid.Column="4"
                            CornerRadius="8" Padding="8,3"
                            Background="{DynamicResource BgElevatedBrush}"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding SpeedLabel}"
                                 FontSize="11"
                                 Foreground="{DynamicResource TextMutedBrush}" />
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Empty state -->
          <Border IsVisible="{Binding !RecentFlips.Count}"
                  Padding="0,20">
            <StackPanel HorizontalAlignment="Center" Spacing="8">
              <TextBlock Text="📊" FontSize="32" HorizontalAlignment="Center" />
              <TextBlock Text="No flips yet — start the script to begin."
                         FontSize="13"
                         Foreground="{DynamicResource TextMutedBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>

        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
