<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             xmlns:m="using:Frikadellen.UI.Models"
             x:Class="Frikadellen.UI.Views.EventsView"
             x:DataType="vm:EventsViewModel">

  <UserControl.Styles>
    <!-- Feed entrance -->
    <Style Selector="Border.events-feed">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="16" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">

    <!-- ── HEADER ── -->
    <Border Grid.Row="0"
            Background="{DynamicResource BgCardBrush}"
            CornerRadius="16"
            Padding="24,18"
            Margin="0,0,0,16"
            BoxShadow="0 4 20 0 #25000000, 0 0 1 0 #12E879F9"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Live Events"
                     FontSize="24" FontWeight="ExtraBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="Real-time activity feed from the script"
                     FontSize="13"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
        <Button Grid.Column="1"
                Classes="pill-ghost"
                VerticalAlignment="Center"
                Command="{Binding ClearCommand}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="🗑" FontSize="13" VerticalAlignment="Center" />
            <TextBlock Text="Clear" FontSize="13" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- ── EVENT FEED — Full width ── -->
    <Border Grid.Row="1"
            Classes="events-feed card"
            Padding="0"
            Opacity="0"
            RenderTransformOrigin="0.5,0">
      <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>
      <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Events}"
                      Margin="16,12">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="m:EventItem">
              <Border Padding="16,14" CornerRadius="14"
                      Margin="0,0,0,6"
                      Cursor="Hand"
                      BorderThickness="0,0,0,0">
                <Border.Styles>
                  <Style Selector="Border:pointerover">
                    <Setter Property="Background" Value="#08FFFFFF" />
                  </Style>
                </Border.Styles>

                <Grid ColumnDefinitions="Auto,*,Auto">
                  <!-- Avatar chip with gradient border -->
                  <Border Grid.Column="0"
                          Width="42" Height="42"
                          CornerRadius="14"
                          Background="{DynamicResource BgElevatedBrush}"
                          Margin="0,0,14,0"
                          VerticalAlignment="Top"
                          BoxShadow="0 0 8 0 #10E879F9">
                    <TextBlock Text="{Binding Avatar}"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>

                  <!-- Content -->
                  <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <!-- Type badge -->
                      <Border CornerRadius="8" Padding="8,3"
                              Background="#1822D3EE">
                        <TextBlock Text="{Binding Type}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentSecondaryBrush}" />
                      </Border>
                      <TextBlock Text="{Binding TimeLabel}"
                                 FontSize="10"
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding Message}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2" />
                  </StackPanel>

                  <!-- Expand arrow -->
                  <TextBlock Grid.Column="2"
                             Text="{Binding IsExpanded, Converter={x:Static vm:ExpandArrowConverter.Instance}}"
                             FontSize="12"
                             Foreground="{DynamicResource TextMutedBrush}"
                             VerticalAlignment="Center"
                             Margin="12,0,0,0" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

  </Grid>
</UserControl>
