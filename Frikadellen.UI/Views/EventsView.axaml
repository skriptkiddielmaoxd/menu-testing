<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             xmlns:m="using:Frikadellen.UI.Models"
             x:Class="Frikadellen.UI.Views.EventsView"
             x:DataType="vm:EventsViewModel">

  <Grid ColumnDefinitions="*,340" RowDefinitions="Auto,*">

    <!-- ── HEADER ── -->
    <Grid Grid.Row="0" Grid.ColumnSpan="2"
          ColumnDefinitions="*,Auto"
          Margin="0,0,0,20">
      <StackPanel Grid.Column="0" Spacing="4">
        <TextBlock Text="Live Events"
                   FontSize="26" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock Text="Real-time activity feed from the script"
                   FontSize="13"
                   Foreground="{DynamicResource TextMutedBrush}" />
      </StackPanel>
      <Button Grid.Column="1"
              Classes="pill-ghost"
              VerticalAlignment="Center"
              Command="{Binding ClearCommand}">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="🗑" FontSize="13" VerticalAlignment="Center" />
          <TextBlock Text="Clear" FontSize="13" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- ── EVENT FEED ── -->
    <Border Grid.Row="1" Grid.Column="0"
            Classes="card"
            Margin="0,0,12,0"
            Padding="0">
      <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Events}"
                      Margin="16,12">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="m:EventItem">
              <Border Padding="14,12" CornerRadius="12"
                      Margin="0,0,0,6"
                      Cursor="Hand">
                <Border.Styles>
                  <Style Selector="Border:pointerover">
                    <Setter Property="Background" Value="#0FFFFFFF" />
                  </Style>
                </Border.Styles>

                <Grid ColumnDefinitions="Auto,*,Auto">
                  <!-- Avatar chip -->
                  <Border Grid.Column="0"
                          Width="38" Height="38"
                          CornerRadius="12"
                          Background="{DynamicResource BgElevatedBrush}"
                          Margin="0,0,12,0"
                          VerticalAlignment="Top">
                    <TextBlock Text="{Binding Avatar}"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>

                  <!-- Content -->
                  <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <!-- Type badge -->
                      <Border CornerRadius="6" Padding="6,2">
                        <Border.Styles>
                          <Style Selector="Border">
                            <Setter Property="Background" Value="#1538BDF8" />
                          </Style>
                        </Border.Styles>
                        <TextBlock Text="{Binding Type}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentSecondaryBrush}" />
                      </Border>
                      <TextBlock Text="{Binding TimeLabel}"
                                 FontSize="10"
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding Message}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2" />
                  </StackPanel>

                  <!-- Expand arrow -->
                  <TextBlock Grid.Column="2"
                             Text="{Binding IsExpanded, Converter={x:Static vm:ExpandArrowConverter.Instance}}"
                             FontSize="12"
                             Foreground="{DynamicResource TextMutedBrush}"
                             VerticalAlignment="Center"
                             Margin="10,0,0,0" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <!-- ── DETAIL PANEL ── -->
    <Border Grid.Row="1" Grid.Column="1"
            Classes="card"
            Padding="20">
      <!-- No selection -->
      <StackPanel IsVisible="{Binding SelectedEvent, Converter={x:Static vm:NullToBoolConverter.Instance}, ConverterParameter=invert}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="10">
        <TextBlock Text="📋" FontSize="36" HorizontalAlignment="Center" />
        <TextBlock Text="Select an event to see details"
                   FontSize="13"
                   Foreground="{DynamicResource TextMutedBrush}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
