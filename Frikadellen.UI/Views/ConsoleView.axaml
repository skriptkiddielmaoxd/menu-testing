<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             xmlns:svc="using:Frikadellen.UI.Services"
             x:Class="Frikadellen.UI.Views.ConsoleView"
             x:DataType="vm:ConsoleViewModel">

  <UserControl.Resources>
    <vm:BoolToStringConverter x:Key="BoolToRunningText"
                               TrueValue="Running" FalseValue="Stopped" />
    <vm:BoolToColorConverter  x:Key="BoolToRunningColor"
                               TrueColor="#4ADE80" FalseColor="#FB7185" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Border.console-enter">
      <Style.Animations>
        <Animation Duration="0:0:0.4" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="16" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">

    <!-- ── HEADER ── -->
    <Border Grid.Row="0"
            Background="{DynamicResource BgCardBrush}"
            CornerRadius="16"
            Padding="24,18"
            Margin="0,0,0,16"
            BoxShadow="0 4 20 0 #25000000, 0 0 1 0 #12E879F9"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Console"
                     FontSize="24" FontWeight="ExtraBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="Rust backend stdout / stderr passthrough"
                     FontSize="13"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>

        <!-- Controls -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center">

          <!-- Exe path input -->
          <TextBox Classes="field"
                   Text="{Binding ExePath}"
                   Watermark="path/to/frikadellen"
                   Width="220"
                   ToolTip.Tip="Path to the Rust binary" />

          <!-- Start -->
          <Button Classes="pill-primary"
                  Command="{Binding StartCommand}"
                  ToolTip.Tip="Start the Rust process">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="▶" FontSize="12" VerticalAlignment="Center" />
              <TextBlock Text="Start" FontSize="13" FontWeight="SemiBold"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <!-- Stop -->
          <Button Classes="pill-ghost"
                  Command="{Binding StopCommand}"
                  ToolTip.Tip="Kill the Rust process">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="⏹" FontSize="12" VerticalAlignment="Center" />
              <TextBlock Text="Stop" FontSize="13" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <!-- Clear -->
          <Button Classes="pill-ghost"
                  Command="{Binding ClearCommand}"
                  ToolTip.Tip="Clear console output">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="🗑" FontSize="13" VerticalAlignment="Center" />
              <TextBlock Text="Clear" FontSize="13" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

        </StackPanel>
      </Grid>
    </Border>

    <!-- ── CONSOLE OUTPUT ── -->
    <Border Grid.Row="1"
            Classes="console-enter card"
            Padding="0"
            Opacity="0"
            RenderTransformOrigin="0.5,0"
            Background="#0D0A16"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1">
      <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>

      <Grid RowDefinitions="*,Auto">

        <!-- Scrolling log lines -->
        <ScrollViewer Grid.Row="0"
                      Name="LogScroller"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Lines}"
                        Margin="16,12">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="svc:ConsoleLineItem">
                <Grid ColumnDefinitions="Auto,*" Margin="0,1">
                  <!-- Timestamp -->
                  <TextBlock Grid.Column="0"
                             Text="{Binding TimeLabel}"
                             FontFamily="Cascadia Code,Consolas,monospace"
                             FontSize="11"
                             Foreground="#4A5568"
                             Margin="0,0,12,0"
                             VerticalAlignment="Top" />
                  <!-- Message -->
                  <TextBlock Grid.Column="1"
                             Text="{Binding Text}"
                             FontFamily="Cascadia Code,Consolas,monospace"
                             FontSize="12"
                             Foreground="{Binding Foreground}"
                             TextWrapping="NoWrap" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- Empty-state overlay -->
        <Border Grid.Row="0"
                IsVisible="{Binding !Lines.Count}"
                Padding="0,48">
          <StackPanel HorizontalAlignment="Center" Spacing="12">
            <TextBlock Text="⬛" FontSize="40" HorizontalAlignment="Center" />
            <TextBlock Text="No output yet — start the Rust process above."
                       FontSize="13"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="1"
                Background="#0A0714"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                     Fill="{Binding IsRunning, Converter={StaticResource BoolToRunningColor}}" />
            <TextBlock Text="{Binding IsRunning, Converter={StaticResource BoolToRunningText}}"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding Lines.Count, StringFormat='{}{0} lines'}"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Border>

      </Grid>
    </Border>

  </Grid>
</UserControl>

