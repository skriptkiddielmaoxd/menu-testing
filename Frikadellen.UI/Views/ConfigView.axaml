<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             x:Class="Frikadellen.UI.Views.ConfigView"
             x:DataType="vm:ConfigViewModel">

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="0" Margin="0,0,8,0" MaxWidth="860">

      <!-- ── PAGE HEADER ── -->
      <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,24">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Configuration"
                     FontSize="26" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="All settings are saved to config/ui-settings.json"
                     FontSize="13"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                    VerticalAlignment="Center">
          <TextBlock Text="{Binding SaveStatus}"
                     FontSize="12"
                     Foreground="{DynamicResource AccentSuccessBrush}"
                     VerticalAlignment="Center"
                     Opacity="0.9" />
          <Button Classes="pill-primary"
                  Command="{Binding SaveCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <TextBlock Text="💾" FontSize="13" VerticalAlignment="Center" />
              <TextBlock Text="Save" FontSize="13" FontWeight="SemiBold"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <!-- ════ FLIP TOGGLES ════ -->
      <Border Classes="card">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Width="28" Height="28" CornerRadius="8"
                    Background="#15818CF8">
              <TextBlock Text="🎯" FontSize="14"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Flip Modes"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
          <Border Classes="divider" />
          <WrapPanel Orientation="Horizontal">
            <CheckBox IsChecked="{Binding EnableAhFlips}"
                      Content="Enable AH Flips"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      Margin="0,0,28,8" />
            <CheckBox IsChecked="{Binding EnableBazaarFlips}"
                      Content="Enable Bazaar Flips"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      Margin="0,0,0,8" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <!-- ════ TIMING ════ -->
      <Border Classes="card">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Width="28" Height="28" CornerRadius="8"
                    Background="#1538BDF8">
              <TextBlock Text="⏱" FontSize="14"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Timing &amp; Delays"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
          <Border Classes="divider" />
          <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
            <StackPanel Grid.Column="0" Grid.Row="0" Spacing="6" Margin="0,0,12,12">
              <TextBlock Text="FLIP ACTION DELAY (ms)" Classes="section-title" />
              <TextBox Classes="field" Text="{Binding FlipActionDelay}"
                       ToolTip.Tip="Delay after opening flip GUI (default 150)" />
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.Row="0" Spacing="6" Margin="0,0,12,12">
              <TextBlock Text="COMMAND DELAY (ms)" Classes="section-title" />
              <TextBox Classes="field" Text="{Binding CommandDelayMs}"
                       ToolTip.Tip="Min delay between queued commands (default 500)" />
            </StackPanel>
            <StackPanel Grid.Column="2" Grid.Row="0" Spacing="6" Margin="0,0,0,12">
              <TextBlock Text="BED SPAM DELAY (ms)" Classes="section-title" />
              <TextBox Classes="field" Text="{Binding BedSpamClickDelay}"
                       ToolTip.Tip="Delay between bed spam clicks (default 100)" />
            </StackPanel>
            <StackPanel Grid.Column="0" Grid.Row="1" Spacing="6" Margin="0,0,12,0">
              <TextBlock Text="BAZAAR CHECK INTERVAL (s)" Classes="section-title" />
              <TextBox Classes="field" Text="{Binding BazaarOrderCheckIntervalSeconds}"
                       ToolTip.Tip="How often to check bazaar orders (default 30s)" />
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.Row="1" Spacing="6" Margin="0,0,12,0">
              <TextBlock Text="BAZAAR CANCEL AFTER (min)" Classes="section-title" />
              <TextBox Classes="field" Text="{Binding BazaarOrderCancelMinutes}"
                       ToolTip.Tip="Cancel bazaar orders older than this (default 5)" />
            </StackPanel>
            <StackPanel Grid.Column="2" Grid.Row="1" Spacing="6">
              <TextBlock Text="AUCTION DURATION (hrs)" Classes="section-title" />
              <TextBox Classes="field" Text="{Binding AuctionDurationHours}"
                       ToolTip.Tip="Duration of listed auctions (default 24)" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ════ BEHAVIOUR ════ -->
      <Border Classes="card">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Width="28" Height="28" CornerRadius="8"
                    Background="#15FBBF24">
              <TextBlock Text="⚙" FontSize="14"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Behaviour"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
          <Border Classes="divider" />
          <WrapPanel Orientation="Horizontal">
            <CheckBox IsChecked="{Binding BedSpam}"
                      Content="Bed Spam"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      Margin="0,0,28,8" />
            <CheckBox IsChecked="{Binding UseCoflChat}"
                      Content="Cofl Chat"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      Margin="0,0,28,8" />
            <CheckBox IsChecked="{Binding Fastbuy}"
                      Content="Fastbuy (skip confirmation)"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      Margin="0,0,0,8" />
          </WrapPanel>
          <StackPanel Spacing="6" MaxWidth="200" HorizontalAlignment="Left">
            <TextBlock Text="AUTO COOKIE INTERVAL" Classes="section-title" />
            <TextBox Classes="field" Text="{Binding AutoCookie}"
                     ToolTip.Tip="0 = disabled" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ════ SKIP FILTER ════ -->
      <Border Classes="card">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Width="28" Height="28" CornerRadius="8"
                    Background="#15F87171">
              <TextBlock Text="🚫" FontSize="14"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Skip Filter"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
          <Border Classes="divider" />
          <Grid ColumnDefinitions="*,*,*">
            <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,12,0">
              <TextBlock Text="MIN PROFIT" Classes="section-title" />
              <TextBox Classes="field" Text="{Binding SkipMinProfit}"
                       ToolTip.Tip="Skip flips with profit below this value (default 1,000,000)" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="6" Margin="0,0,12,0">
              <TextBlock Text="PROFIT % THRESHOLD" Classes="section-title" />
              <TextBox Classes="field" Text="{Binding SkipProfitPercentage}"
                       ToolTip.Tip="Skip flips below this profit % (default 50)" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="6">
              <TextBlock Text="MIN PRICE" Classes="section-title" />
              <TextBox Classes="field" Text="{Binding SkipMinPrice}"
                       ToolTip.Tip="Skip items below this price (default 10,000,000)" />
            </StackPanel>
          </Grid>
          <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
            <CheckBox IsChecked="{Binding SkipAlways}"
                      Content="Skip Always (pause)"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      Margin="0,0,28,4" />
            <CheckBox IsChecked="{Binding SkipUserFinder}"
                      Content="Skip User Finder"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      Margin="0,0,28,4" />
            <CheckBox IsChecked="{Binding SkipSkins}"
                      Content="Skip Skins"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      Margin="0,0,0,4" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <!-- ════ NETWORK ════ -->
      <Border Classes="card">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Width="28" Height="28" CornerRadius="8"
                    Background="#1534D399">
              <TextBlock Text="🌐" FontSize="14"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Network"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
          <Border Classes="divider" />
          <StackPanel Spacing="6">
            <TextBlock Text="WEBHOOK URL" Classes="section-title" />
            <TextBox Classes="field" Text="{Binding WebhookUrl}"
                     Watermark="https://discord.com/api/webhooks/…"
                     ToolTip.Tip="Discord webhook for notifications (empty = disabled)" />
          </StackPanel>
          <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
            <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,12,0">
              <TextBlock Text="WEB GUI PORT" Classes="section-title" />
              <TextBox Classes="field" Text="{Binding WebGuiPort}"
                       ToolTip.Tip="Port for the built-in web dashboard (default 8080)" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="6">
              <TextBlock Text="PROXY (SOCKS5)" Classes="section-title" />
              <TextBox Classes="field" Text="{Binding Proxy}"
                       Watermark="socks5://..."
                       IsEnabled="{Binding ProxyEnabled}"
                       ToolTip.Tip="SOCKS5 proxy address" />
            </StackPanel>
          </Grid>
          <CheckBox IsChecked="{Binding ProxyEnabled}"
                    Content="Enable Proxy"
                    Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
